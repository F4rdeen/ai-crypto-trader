# ============================================================
# .env.example — AI Crypto Trader
#
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# NEVER commit .env to version control.
# ============================================================

# --- Exchange credentials (required) ---
EXCHANGE_ID=binance
EXCHANGE_API_KEY=your_api_key_here
EXCHANGE_SECRET=your_api_secret_here

# --- Trading parameters ---
SYMBOL=BTC/USDT
TIMEFRAME=15m
TRADE_AMOUNT_USDT=50

# --- Model path (must exist before running the live engine) ---
MODEL_PATH=btc_xgboost_bot_v1.pkl

# --- Alerting (optional) ---
# POST endpoint that receives JSON trade/error notifications.
# Works with n8n, Telegram bots, Discord webhooks, etc.
# Leave blank to disable.
WEBHOOK_URL=

# --- Logging ---
# One of: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
